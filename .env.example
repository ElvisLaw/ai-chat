# AI Chat Configuration
# Copy this file to .env and fill in your API keys
# DO NOT commit .env to version control

# MiniMax API (OpenAI compatible)
# Get your API key from https://platform.minimaxi.com
OPENAI_API_KEY=your-minimax-api-key-here
OPENAI_BASE_URL=https://api.minimaxi.com/v1

# OpenAI API (optional, if not using MiniMax)
# OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API (optional)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model configuration
# MiniMax models: MiniMax-M2.7, MiniMax-Text-01
# OpenAI models: gpt-4, gpt-3.5-turbo
MODEL=MiniMax-M2.7

# Optional settings
MAX_TOKENS=4096
TEMPERATURE=0.7
